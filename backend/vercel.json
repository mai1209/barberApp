{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "crons": [
    {
      "path": "/api/appointments/reminders/run",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/auth/subscription/lifecycle/run",
      "schedule": "0 11 * * *"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
